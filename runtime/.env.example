# Copy to runtime/.env and fill in your keys:
#   cp .env.example .env

ANTHROPIC_API_KEY=
GROQ_API_KEY=
INJECTIVE_NETWORK=testnet
INJECTIVE_WALLET_ADDRESS=
INJECTIVE_WALLET_PASSWORD=
MCP_SERVER_PATH=/absolute/path/to/InjectiveLabs/mcp-server/dist/mcp/server.js
MCP_HANDSHAKE_TIMEOUT=15
MCP_TOOL_CALL_TIMEOUT=30
MCP_REQUEST_TIMEOUT=120

# Demo-safe defaults — judges should keep these unless doing a deliberate live testnet trade
SIMULATOR_MODE=true
DRY_RUN=true

# Optional: real on-chain proof-of-execution for recording (OFF by default)
# When enabled, the Executor substitutes an on-chain USDT `transfer_send` for a perp trade
# to produce an explorer-verifiable testnet tx.
DEMO_REAL_TX=false
DEMO_TX_AMOUNT=0.1
# Must be a DIFFERENT inj1... recipient address (MCP blocks self-transfers).
DEMO_TX_RECIPIENT=

SENTINEL_DB_PATH=./sentinel.db
KILL_SWITCH=false
POLL_INTERVAL=8
WATCHER_MARKETS=BTC,ETH,INJ
SENTINEL_HOST=0.0.0.0
# Render sets PORT automatically; use PORT locally if you override the listen port
PORT=8000

# Security (leave empty for local dev without auth; required in production)
SENTINEL_ENV=development
SENTINEL_API_KEY=
REQUIRE_API_KEY=false
CORS_ORIGINS=http://localhost:3000
ENABLE_DOCS=true

# Optional — used by tooling/docs; dashboard uses RUNTIME_API_URL in .env.local
RUNTIME_API_URL=http://127.0.0.1:8000
