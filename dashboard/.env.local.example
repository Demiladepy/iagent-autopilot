# REST proxy (server-side, Next.js → runtime)
RUNTIME_API_URL=http://127.0.0.1:8000

# Must match runtime SENTINEL_API_KEY when auth is enabled (server-side only)
SENTINEL_API_KEY=change-me-in-production

# Proof of Execution — static testnet receipt (client-readable, no runtime fetch)
# Populate from a real DEMO_REAL_TX=true run; leave NEXT_PUBLIC_PROOF_TX_HASH empty to hide proof.
NEXT_PUBLIC_PROOF_TX_HASH=
NEXT_PUBLIC_PROOF_TX_TYPE=transfer_send
NEXT_PUBLIC_PROOF_ASSET=USDT
NEXT_PUBLIC_PROOF_AMOUNT=0.1
NEXT_PUBLIC_PROOF_TIMESTAMP=
NEXT_PUBLIC_PROOF_NETWORK=Injective Testnet

# Example (replace with your verified hash from runtime/sentinel.db or explorer):
# NEXT_PUBLIC_PROOF_TX_HASH=CBB6D454FE682DECD37F52DE101CD00F9C22188DB825EDC4A34F69C41E50BCC7
# NEXT_PUBLIC_PROOF_TIMESTAMP=2026-05-30T06:04:26.579294+00:00
